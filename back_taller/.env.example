DATABASE_URL="file:./dev.db"
PORT=4000
CORS_ORIGIN="http://localhost:3000"

# Google Calendar (cuenta: thomasduranrojas@gmail.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/oauth2callback"
GOOGLE_REFRESH_TOKEN=""
GOOGLE_CALENDAR_ID="primary"

# Clave para panel del mecánico (Authorization: Bearer <clave>)
MECHANIC_API_KEY="cambia-esta-clave-segura"

# Clave opcional para administrador (mismos permisos de recepción/entrega)
ADMIN_API_KEY=""

# Correo de confirmación para registro de mecánicos (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="tu-correo@gmail.com"
SMTP_PASS="tu-contraseña-de-aplicacion"
SMTP_FROM="Moto Taller <tu-correo@gmail.com>"

# WhatsApp automático — Green API (https://green-api.com)
# 1. Regístrate en https://console.green-api.com
# 2. Crea una instancia y escanea el QR con el WhatsApp del taller
# 3. Copia idInstance y apiTokenInstance cuando el estado sea "Authorized"
GREEN_API_INSTANCE_ID=""
GREEN_API_TOKEN=""
GREEN_API_URL="https://api.greenapi.com"
# Desactiva whatsapp-web.js cuando uses Green API (recomendado)
WHATSAPP_BAILEYS="true"
# Carpeta de sesión WhatsApp (opcional; por defecto: %USERPROFILE%\.moto-taller-whatsapp)
WHATSAPP_AUTH_DIR=""

# Notificación al administrador cuando un mecánico finaliza un trabajo
ADMIN_NOTIFY_EMAIL=""
ADMIN_NOTIFY_PHONE=""

# Alternativa oficial: Meta WhatsApp Cloud API (https://developers.facebook.com)
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
# Plantilla aprobada en Meta (nombre exacto). Ejemplo de cuerpo:
# Hola {{1}}, tu cita en Moto Taller Familiar quedó confirmada para el {{2}}. {{3}} Por favor lleva tu moto ese día. Dirección: {{4}}. ¡Te esperamos!
WHATSAPP_TEMPLATE_NAME="cita_confirmada"
WHATSAPP_TEMPLATE_LANGUAGE="es"
