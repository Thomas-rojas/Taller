generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Servicio {
  id          String   @id @default(cuid())
  titulo      String
  descripcion String
  icono       String   @default("⚙️")
  activo      Boolean  @default(true)
  orden       Int      @default(0)
  citas       Cita[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Cita {
  id                       String         @id @default(cuid())
  nombre                   String
  telefono                 String
  email                    String?
  mensaje                  String?
  placa                    String?
  estadoMotoIngreso        String?
  descripcionTrabajo       String?
  datosReparacionBloqueados Boolean       @default(false)
  registradoPor            String?
  fechaPreferida           DateTime?
  fechaRecepcion           DateTime?
  fechaEntrega             DateTime?
  fechaEntregaReal         DateTime?
  googleEventId            String?
  estado                   String         @default("pendiente")
  servicioId               String?
  servicio                 Servicio?      @relation(fields: [servicioId], references: [id], onDelete: SetNull)
  diasBloqueados           DiaBloqueado[]
  actividades              CitaActividad[]
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
}

model CitaActividad {
  id          String   @id @default(cuid())
  citaId      String
  cita        Cita     @relation(fields: [citaId], references: [id], onDelete: Cascade)
  tipo        String
  titulo      String
  descripcion String?
  datos       String?
  createdAt   DateTime @default(now())

  @@index([citaId, createdAt])
}

model DiaBloqueado {
  id        String   @id @default(cuid())
  fecha     String
  citaId    String
  cita      Cita     @relation(fields: [citaId], references: [id], onDelete: Cascade)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fecha, citaId])
  @@index([fecha, activo])
}

model GaleriaItem {
  id          String   @id @default(cuid())
  src         String
  alt         String
  titulo      String
  descripcion String
  size        String   @default("small")
  orden       Int      @default(0)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MensajeChat {
  id        String   @id @default(cuid())
  mensaje   String
  respuesta String?
  createdAt DateTime @default(now())
}

model PreguntaFrecuente {
  id        String   @id @default(cuid())
  pregunta  String
  respuesta String
  activo    Boolean  @default(true)
  orden     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Configuracion {
  id        String   @id @default("default")
  whatsapp  String
  telefono  String
  direccion String
  horario   String?
  instagram String?
  facebook  String?
  youtube   String?
  updatedAt DateTime @updatedAt
}

model Mecanico {
  id                 String    @id @default(cuid())
  email              String    @unique
  nombre             String
  apellidos          String
  celular            String    @unique
  direccion          String    @default("")
  tipoIdentificacion String
  identificacion     String
  passwordHash       String
  aprobado           Boolean   @default(false)
  activo             Boolean   @default(true)
  sessionToken       String?   @unique
  sessionExpiresAt   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([tipoIdentificacion, identificacion])
}

model Cliente {
  id               String       @id @default(cuid())
  nombre           String
  telefono         String       @unique
  email            String       @unique
  passwordHash     String
  activo           Boolean      @default(true)
  sessionToken     String?      @unique
  sessionExpiresAt DateTime?
  testimonio       Testimonio?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Testimonio {
  id        String   @id @default(cuid())
  clienteId String   @unique
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  nombre    String
  moto      String
  texto     String
  publicado Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
